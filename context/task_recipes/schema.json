{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/the-modern-prometheus/task-recipe.schema.json",
  "title": "Task Recipe",
  "description": "Machine-readable workflow recipe for stateless operators.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "title",
    "scope",
    "target_files",
    "dependencies",
    "commands",
    "validations",
    "done_when"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 5
    },
    "scope": {
      "type": "string",
      "minLength": 10
    },
    "target_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "context_sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "command", "purpose"],
        "properties": {
          "name": {"type": "string"},
          "command": {"type": "string"},
          "purpose": {"type": "string"}
        }
      }
    },
    "validations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "method", "pass_condition"],
        "properties": {
          "name": {"type": "string"},
          "method": {"type": "string"},
          "pass_condition": {"type": "string"}
        }
      }
    },
    "done_when": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
